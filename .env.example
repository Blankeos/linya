# ===========================================================================
# Required
# ===========================================================================

# PostgreSQL connection string (matches docker/docker-compose.db.yml)
DATABASE_URL="postgresql://postgres:password123@localhost:5432/linya"

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars"

# Your app's public URL (no trailing slash)
PUBLIC_BASE_URL="http://localhost:3000"

# Self-hosted PowerSync instance URL (no trailing slash)
PUBLIC_POWERSYNC_URL="http://localhost:8080"

# ===========================================================================
# Optional — Auth token lifetimes
# ===========================================================================
REFRESH_TOKEN_EXPIRES_DAYS=7
ACCESS_TOKEN_EXPIRES_MINUTES=15

# ===========================================================================
# Optional — OAuth (leave blank to disable)
# ===========================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ===========================================================================
# Optional — S3-compatible storage (for avatar uploads)
# ===========================================================================
S3_BUCKET_NAME=linya
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ===========================================================================
# Optional — Email delivery (console | smtp | zepto)
# ===========================================================================
EMAIL_PROVIDER=console

# SMTP (EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ZeptoMail (EMAIL_PROVIDER=zepto)
ZEPTOMAIL_TOKEN=
ZEPTOMAIL_FROM="Linya <noreply@linya.app>"

# ===========================================================================
# Optional — Environment
# ===========================================================================
NODE_ENV=development
